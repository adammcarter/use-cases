{
  "name": "@use-case-matrix/mcp",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server for use-case-matrix.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adammcarter/presentation-skills.git",
    "directory": "packages/ucm-mcp"
  },
  "bin": {
    "ucm-mcp": "./dist/index.js",
    "use-case-matrix-mcp": "./dist/index.js"
  },
