{
  "name": "@adammcarter/use-cases-cli",
  "version": "0.4.2",
  "type": "module",
  "description": "CLI for @adammcarter/use-cases.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adammcarter/use-cases.git",
    "directory": "packages/cli"
  },
  "bin": {
    "uc": "./dist/index.js",
    "use-cases": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "private": true,
  "dependencies": {
    "@adammcarter/use-cases-core": "workspace:*"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "prepublishOnly": "tsc -b"
  }
}
