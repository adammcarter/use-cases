{
  "name": "use-cases-plugin",
  "version": "1.0.0",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adammcarter/use-cases-plugin.git"
  },
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "ucp": "./packages/ucm-cli/dist/index.js",
    "use-cases-plugin": "./packages/ucm-cli/dist/index.js",
    "ucp-mcp": "./packages/ucm-mcp/dist/index.js",
    "use-cases-plugin-mcp": "./packages/ucm-mcp/dist/index.js"
  },
  "files": [
    ".agents/skills",
    ".claude-plugin/plugin.json",
    ".codex-plugin/plugin.json",
    ".mcp.json",
    ".opencode/plugin/use-cases-plugin.js",
    "hooks",
    "README.md",
    "CHANGELOG.md",
    "bootstrap",
    "docs/acceptance.md",
    "docs/activation.md",
    "docs/adr",
    "docs/cli.md",
    "docs/data-model.md",
    "docs/hosts.md",
    "docs/markers-adoption.md",
    "docs/mcp.md",
    "docs/migration.md",
    "docs/release.md",
    "docs/security.md",
    "docs/showcase.md",
    "examples",
    "hosts",
    "packages/ucm-cli/dist",
    "packages/ucm-cli/package.json",
    "packages/ucm-core/dist",
    "packages/ucm-core/package.json",
    "packages/ucm-mcp/dist",
    "packages/ucm-mcp/package.json",
    "plugin.json",
    "use-cases-plugin.yml",
    "schemas/v1",
    "use-cases"
  ],
  "scripts": {
    "build": "tsc -b packages/ucm-core packages/ucm-cli packages/ucm-mcp && node packages/ucm-core/scripts/copy-schemas.mjs && chmod +x packages/ucm-cli/dist/index.js packages/ucm-mcp/dist/index.js",
    "clean": "rm -rf packages/*/dist coverage",
    "cli": "node packages/ucm-cli/dist/index.js",
    "lint": "tsc -b --pretty false --dry",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.9.0"
  }
}
