#!/usr/bin/env bash
# SessionStart hook for the use-case-matrix.
#
# Emits the trusted bootstrap (bootstrap/use-case-matrix.md) as session-start
# context so an installed agent receives it without having to discover it by
# reading the repo. One script serves three hosts; the JSON shape is chosen from
# the host's env (see critical-info-bootstrap / delivery-shapes):
#   - Claude Code (CLAUDE_PLUGIN_ROOT, not Copilot) -> hookSpecificOutput.additionalContext
#   - Copilot CLI  (COPILOT_CLI)                    -> top-level additionalContext
#   - Codex / other                                 -> hookSpecificOutput.additionalContext
# OpenCode uses a native plugin instead (.opencode/plugin/use-case-matrix.js).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

bootstrap_content=$(cat "${PLUGIN_ROOT}/bootstrap/use-case-matrix.md" 2>&1 || echo "Error reading use-case-matrix bootstrap")

# Single C-level pass per replacement; far faster than a char loop.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

session_context=$(escape_for_json "$bootstrap_content")

# printf (not heredoc) avoids the bash 5.3+ heredoc hang.
#: @use-case: hosts.profiles.bootstrap_autoinject
if [ -n "${COPILOT_CLI:-}" ]; then
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
else
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
fi
#: @use-case: end hosts.profiles.bootstrap_autoinject

exit 0
