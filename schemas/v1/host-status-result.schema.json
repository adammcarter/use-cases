{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://use-cases.dev/schemas/v1/host-status-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "status": {
      "enum": [
        "expected",
        "installed",
        "projected",
        "conformant_static",
        "verified_with_evidence",
        "partial_with_evidence",
        "blocked",
        "unsupported",
        "not_tested"
      ]
    },
    "profile_id": { "$ref": "common.schema.json#/$defs/id" },
    "host_surface": { "$ref": "common.schema.json#/$defs/host_surface" },
    "host_version": { "type": "string", "minLength": 1 },
    "environment": { "type": "object" },
    "evidence_event_ids": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/id" }
    },
    "assessed_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" }
  },
  "required": ["schema_version", "status", "profile_id", "host_surface", "host_version", "environment", "evidence_event_ids", "assessed_at"],
  "allOf": [
    {
      "if": {
        "properties": { "status": { "enum": ["verified_with_evidence", "partial_with_evidence"] } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "evidence_event_ids": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    }
  ]
}
