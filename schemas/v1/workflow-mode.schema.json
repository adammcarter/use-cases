{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://use-cases.dev/schemas/v1/workflow-mode.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "mode": {
      "enum": ["continuous", "backfill", "showcase_only", "audit_only", "migration", "custom"]
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" }
  },
  "required": ["schema_version", "mode"]
}
