{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://use-cases.dev/schemas/v1/demo-capsule.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "capsule_id": { "$ref": "common.schema.json#/$defs/id" },
    "title": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["showcase", "walkthrough"] },
    "description": { "type": "string", "minLength": 1 },
    "audience": { "type": "string", "minLength": 1 },
    "timebox_seconds": { "type": "integer", "minimum": 1 },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "use_case_id": { "$ref": "common.schema.json#/$defs/id" },
          "scenario_ids": {
            "type": "array",
            "items": { "$ref": "common.schema.json#/$defs/id" }
          },
          "runbook": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "kind": { "const": "instruction" },
                    "text": { "type": "string", "minLength": 1 }
                  },
                  "required": ["kind", "text"]
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "kind": { "const": "observation" },
                    "text": { "type": "string", "minLength": 1 }
                  },
                  "required": ["kind", "text"]
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "kind": { "const": "command" },
                    "executable": { "type": "string", "minLength": 1 },
                    "argv": { "type": "array", "items": { "type": "string" } },
                    "working_directory": { "type": "string" },
                    "expected_exit_codes": { "type": "array", "items": { "type": "integer" } }
                  },
                  "required": ["kind", "executable", "argv", "working_directory", "expected_exit_codes"]
                }
              ]
            }
          }
        },
        "required": ["use_case_id", "runbook"]
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command_execution": { "type": "boolean" }
      },
      "required": ["command_execution"]
    },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" }
  },
  "required": ["schema_version", "capsule_id", "title", "mode", "description", "audience", "timebox_seconds", "items", "permissions"]
}
