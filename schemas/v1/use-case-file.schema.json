{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presentation-skills.dev/schemas/v1/use-case-file.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/id" },
        "name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      },
      "required": ["id", "name", "summary"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "lifecycle": { "enum": ["planned", "active", "deprecated", "removed"] },
        "extensions": { "$ref": "common.schema.json#/$defs/extensions" }
      }
    },
    "use_cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/use_case" }
    },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" }
  },
  "required": ["schema_version", "feature", "use_cases"],
  "$defs": {
    "use_case": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/id" },
        "title": { "type": "string", "minLength": 1 },
        "lifecycle": { "enum": ["planned", "active", "deprecated", "removed"] },
        "value_tier": { "enum": ["critical", "core", "supporting", "long_tail"] },
        "journey_role": { "enum": ["golden", "alternate", "edge", "negative", "failure"] },
        "usage_frequency": { "enum": ["common", "occasional", "rare"] },
        "actor": { "type": "string", "minLength": 1 },
        "intent": { "type": "string", "minLength": 1 },
        "preconditions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "trigger": { "type": "string", "minLength": 1 },
        "scenarios": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/gherkin_scenario" },
              { "$ref": "#/$defs/steps_scenario" }
            ]
          }
        },
        "observable_outcomes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "host_applicability": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "host_surface": { "$ref": "common.schema.json#/$defs/host_surface" },
              "supported": { "type": "boolean" },
              "notes": { "type": "string" }
            },
            "required": ["host_surface", "supported"]
          }
        },
        "verification_policy": { "$ref": "common.schema.json#/$defs/verification_policy" },
        "approval_policy": { "$ref": "common.schema.json#/$defs/approval_policy" },
        "extensions": { "$ref": "common.schema.json#/$defs/extensions" }
      },
      "required": ["id", "title", "lifecycle", "value_tier", "journey_role", "usage_frequency"],
      "allOf": [
        {
          "if": {
            "properties": { "lifecycle": { "const": "active" } },
            "required": ["lifecycle"]
          },
          "then": {
            "properties": {
              "actor": true,
              "intent": true,
              "preconditions": true,
              "trigger": true,
              "scenarios": true,
              "observable_outcomes": true,
              "host_applicability": true,
              "verification_policy": true,
              "approval_policy": true
            },
            "required": [
              "actor",
              "intent",
              "preconditions",
              "trigger",
              "scenarios",
              "observable_outcomes",
              "host_applicability",
              "verification_policy",
              "approval_policy"
            ]
          }
        }
      ]
    },
    "gherkin_scenario": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/id" },
        "kind": { "const": "gherkin" },
        "given": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "when": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "then": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      },
      "required": ["id", "kind", "given", "when", "then"]
    },
    "steps_scenario": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/id" },
        "kind": { "const": "steps" },
        "steps": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "observable_outcomes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "required": ["id", "kind", "steps"]
    }
  }
}
