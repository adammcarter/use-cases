{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presentation-skills.dev/schemas/v1/host-profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "profile_id": { "$ref": "common.schema.json#/$defs/id" },
    "host": { "enum": ["claude", "codex", "copilot", "opencode"] },
    "surface": { "$ref": "common.schema.json#/$defs/host_surface" },
    "profile_version": { "type": "integer", "minimum": 1 },
    "host_version": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min": { "type": ["string", "null"] },
        "tested": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] }
      },
      "required": ["min", "tested", "notes"]
    },
    "os_runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supported": {
          "type": "array",
          "items": { "enum": ["darwin", "linux", "windows", "unknown"] }
        }
      },
      "required": ["supported"]
    },
    "installation_mode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expected": { "type": "string", "minLength": 1 }
      },
      "required": ["expected"]
    },
    "permission_mode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "expected": { "type": "string", "minLength": 1 }
      },
      "required": ["expected"]
    },
    "expected_capabilities": {
      "type": "object",
      "additionalProperties": { "enum": ["required", "optional", "unsupported"] }
    },
    "projection_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "kind": { "enum": ["activation_stub", "skill_stub"] },
          "path": { "type": "string", "minLength": 1 },
          "managed": { "type": "boolean" },
          "content_policy": { "enum": ["thin_stub", "full_copy_required"] }
        },
        "required": ["kind", "path", "managed", "content_policy"]
      }
    },
    "known_limitations": { "type": "array", "items": { "type": "string" } },
    "doctor_checks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "conformance_checks": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" }
  },
  "required": [
    "schema_version",
    "profile_id",
    "host",
    "surface",
    "profile_version",
    "host_version",
    "os_runtime",
    "installation_mode",
    "permission_mode",
    "expected_capabilities",
    "projection_targets",
    "doctor_checks",
    "conformance_checks",
    "known_limitations"
  ]
}
