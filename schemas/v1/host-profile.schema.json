{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presentation-skills.dev/schemas/v1/host-profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "profile_id": { "$ref": "common.schema.json#/$defs/id" },
    "host": { "enum": ["claude", "codex", "copilot", "opencode"] },
    "surface": { "$ref": "common.schema.json#/$defs/host_surface" },
    "version_constraints": { "type": "object" },
    "installation_shape": { "type": "string", "minLength": 1 },
    "permission_expectations": { "type": "object" },
    "skill_discovery": { "type": "object" },
    "cli_expectations": { "type": "object" },
    "mcp_expectations": { "type": "object" },
    "known_limitations": { "type": "array", "items": { "type": "string" } },
    "required_conformance_capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "extensions": { "$ref": "common.schema.json#/$defs/extensions" }
  },
  "required": ["schema_version", "profile_id", "host", "surface", "version_constraints", "installation_shape", "permission_expectations", "skill_discovery", "cli_expectations", "mcp_expectations", "known_limitations", "required_conformance_capabilities"]
}
